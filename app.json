{
  "expo": {
    "name": "FinanceApp",
    "slug": "financeapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "financeapp",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1117"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.financeapp.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F1117",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "package": "com.financeapp.mobile"
    },
    "plugins": [
      "expo-router",
      [
        "expo-secure-store",
        {
          "keychainServiceName": "com.financeapp.secure"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c21f91aa-d8be-4fb5-9fd5-964ca82f3a7b"
      }
    },
    "owner": "andreluke"
  }
}
